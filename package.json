{
  "name": "prompt-cleaner",
  "displayName": "Prompt Cleaner",
  "publisher": "CiprianCirstea",
  "description": "Cleans up your rambling prompts and sends them directly to Copilot Chat",
  "version": "0.2.4",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/local/copilot-prompt-cleaner"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Prompt Cleaner",
      "properties": {
        "copilotPromptCleaner.endpoint": {
          "type": "string",
          "default": "https://api.openai.com",
          "description": "OpenAI-compatible API endpoint (without /v1)"
        },
        "copilotPromptCleaner.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model to use for cleaning prompts"
        },
        "copilotPromptCleaner.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key (for OpenAI or compatible providers)"
        }
      }
    },
    "commands": [
      {
        "command": "copilotPromptCleaner.cleanPrompt",
        "title": "Clean Prompt"
      },
      {
        "command": "copilotPromptCleaner.openPromptFile",
        "title": "Open Prompt File"
      }
    ],
    "keybindings": [
      {
        "command": "copilotPromptCleaner.cleanPrompt",
        "key": "cmd+shift+r",
        "when": "editorTextFocus"
      },
      {
        "command": "copilotPromptCleaner.openPromptFile",
        "key": "cmd+shift+x"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
